{
  "appId": "com.focusflow.dayplanner",
  "appName": "FocusFlow",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#4F46E5",
      "showSpinner": false,
      "androidSpinnerStyle": "small",
      "spinnerColor": "#ffffff"
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#4F46E5"
    },
    "LocalNotifications": {
      "smallIcon": "ic_launcher_foreground",
      "iconColor": "#4F46E5",
      "sound": "default"
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}
